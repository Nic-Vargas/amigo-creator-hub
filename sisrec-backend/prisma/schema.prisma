generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CARTERA
  AUDITOR
}

enum CaseStatus {
  ABIERTO
  EN_GESTION
  ACUERDO
  EN_PAGO
  CERRADO
}

enum MovementType {
  SALDO_INICIAL
  INCREMENTO
  REINTEGRO
  NO_PROCEDE
  AJUSTE
}

enum MovementConcept {
  SALUD
  PENSION
  CUOTA_MONETARIA
  TRANSFERENCIA_ECONOMICA
  BONO_ALIMENTACION
  BENEFICIOS_ECONOMICOS_488
}

enum Priority {
  ALTA
  MEDIA
  BAJA
}

enum AdjustmentDirection {
  SUMA
  RESTA
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  beneficiaries Beneficiary[]
  recobroCases  RecobroCase[]
  movements     Movement[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String
  passwordHash String
  fullName     String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignedCases RecobroCase[] @relation("CaseResponsible")
  movements     Movement[]

  @@unique([companyId, email])
  @@index([companyId])
}

model Beneficiary {
  id            String   @id @default(cuid())
  companyId     String
  tipoDocumento String
  documento     String
  nombres       String
  apellidos     String
  email         String?
  celular       String?
  telefono      String?
  direccion     String?
  ciudad        String?
  municipio     String?
  departamento  String?
  estado        String?
  saldoTotal    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  recobroCases RecobroCase[]
  movements    Movement[]

  @@unique([companyId, tipoDocumento, documento])
  @@index([companyId])
  @@index([companyId, documento])
}

model RecobroCase {
  id                           String     @id @default(cuid())
  companyId                    String
  beneficiaryId                String
  ley                          String
  periodo                      String
  valorSalud                   Decimal    @default(0) @db.Decimal(18, 2)
  valorPension                 Decimal    @default(0) @db.Decimal(18, 2)
  valorCuotaMonetaria          Decimal    @default(0) @db.Decimal(18, 2)
  valorTransferenciaEconomica  Decimal    @default(0) @db.Decimal(18, 2)
  valorBonoAlimentacion        Decimal    @default(0) @db.Decimal(18, 2)
  valorBeneficiosEconomicos488 Decimal    @default(0) @db.Decimal(18, 2)
  valorTotal                   Decimal    @default(0) @db.Decimal(18, 2)
  estado                       CaseStatus @default(ABIERTO)
  prioridad                    Priority   @default(MEDIA)
  responsableUserId            String?
  ultimaGestionAt              DateTime?
  fechaApertura                DateTime
  createdAt                    DateTime   @default(now())
  updatedAt                    DateTime   @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  beneficiary Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)
  responsable User?       @relation("CaseResponsible", fields: [responsableUserId], references: [id], onDelete: SetNull)
  movements   Movement[]

  @@index([companyId])
  @@index([companyId, beneficiaryId])
  @@index([companyId, estado])
  @@index([companyId, periodo])
}

model Movement {
  id                       String   @id @default(cuid())
  companyId                String
  recobroCaseId            String
  beneficiaryId            String
  userId                   String
  descripcion              String?
  caseTotalAnterior        Decimal  @db.Decimal(18, 2)
  caseTotalNuevo           Decimal  @db.Decimal(18, 2)
  beneficiaryTotalAnterior Decimal  @db.Decimal(18, 2)
  beneficiaryTotalNuevo    Decimal  @db.Decimal(18, 2)
  createdAt                DateTime @default(now())

  company     Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  recobroCase RecobroCase          @relation(fields: [recobroCaseId], references: [id], onDelete: Restrict)
  beneficiary Beneficiary          @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  details     MovementDetail[]
  attachments MovementAttachment[]

  @@index([companyId])
  @@index([companyId, recobroCaseId])
  @@index([companyId, beneficiaryId])
  @@index([companyId, createdAt])
}

model MovementDetail {
  id                    String               @id @default(cuid())
  movementId            String
  tipo                  MovementType
  concepto              MovementConcept
  adjustmentDirection   AdjustmentDirection?
  valor                 Decimal              @db.Decimal(18, 2)
  saldoAnteriorConcepto Decimal              @db.Decimal(18, 2)
  saldoNuevoConcepto    Decimal              @db.Decimal(18, 2)
  createdAt             DateTime             @default(now())

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  @@index([movementId])
  @@index([concepto])
}

model MovementAttachment {
  id          String   @id @default(cuid())
  movementId  String
  fileName    String
  storagePath String
  mimeType    String
  fileSize    Int
  createdAt   DateTime @default(now())

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  @@unique([storagePath])
  @@index([movementId])
}
